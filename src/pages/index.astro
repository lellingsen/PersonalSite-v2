---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/Page.astro';

const mostRecentPost = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)[0];
---

<PageLayout>
  <h1>👋 Hello, friend!</h1>
  <p>
    Most recent post: <a href={`/blog/${mostRecentPost.id}/`}
      >{mostRecentPost.data.title}</a
    >.
  </p>
  <p>
    This is my personal site, which is mainly used to house some of my writing.
    I've been in the software industry for over a decade, having spent around
    half that time as an engineer, and the other half as an engineering manager.
    Currently, I'm a Software Engineer at <a
      href="https://datavant.com/about/careers/">Datavant</a
    >. Most of my writing is about writing software, technology, management, or
    habits.
  </p>
  <p>
    This site is built using <a href="https://docs.astro.build/">Astro</a>
    and <a href="https://www.netlify.com/">Netlify</a>, and is usually matched
    theme-wise to what I'm using in my editor at the time. A previous iteration
    was using Gatsby v2 and Tailwind.
  </p>
  <p>
    Please feel free to look around, connect with me on LinkedIn, or submit a
    pull request if you find a mistake!
  </p>
</PageLayout>
